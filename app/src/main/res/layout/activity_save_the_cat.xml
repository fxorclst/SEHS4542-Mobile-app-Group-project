<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#111122">

    <!-- ══ GAME AREA ══════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/gameArea"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🐱  Save the Cat!"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFD600"
            android:gravity="center"
            android:padding="10dp"
            android:layout_gravity="top"
            android:background="#33FFFFFF" />

        <!-- ── FURNITURE (draggable, spread around room) ───────────── -->

        <!-- Sofa — bottom-left -->
        <TextView
            android:id="@+id/tvSofa"
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:text="🛋️"
            android:textSize="52sp"
            android:gravity="center"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="120dp"
            android:elevation="2dp" />

        <!-- Table — top-right area -->

        <!-- Stove — top-left (danger zone) -->

        <!-- Trash can — bottom-right (goal) -->

        <TextView
            android:id="@+id/tvTable"
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="100dp"
            android:layout_marginEnd="16dp"
            android:elevation="2dp"
            android:gravity="center"
            android:text="🪑"
            android:textSize="52sp" />

        <TextView
            android:id="@+id/tvStove"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="12dp"
            android:layout_marginTop="100dp"
            android:elevation="2dp"
            android:gravity="center"
            android:text="🔥\n🍳"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvTrash"
            android:layout_width="80dp"
            android:layout_height="90dp"
            android:text="🗑️"
            android:textSize="56sp"
            android:gravity="center"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="110dp"
            android:layout_marginEnd="12dp"
            android:elevation="2dp" />

        <!-- Label: Trash -->

        <!-- Label: Stove -->

        <!-- Cat — draggable, center-left -->

        <!-- Bomb — draggable, center -->

        <!-- Timer — near bomb -->

        <TextView
            android:id="@+id/tvCat"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:layout_marginEnd="80dp"
            android:elevation="4dp"
            android:gravity="center"
            android:text="🐱"
            android:textSize="52sp" />

        <TextView
            android:id="@+id/tvBomb"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:layout_marginStart="60dp"
            android:elevation="4dp"
            android:gravity="center"
            android:text="💣"
            android:textSize="52sp" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30s"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#CC000000"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_gravity="center"
            android:layout_marginStart="140dp"
            android:layout_marginBottom="60dp"
            android:elevation="6dp" />

        <!-- Instruction -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Drop 💣 into 🗑️ to win!  Avoid the 🍳 stove!"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:padding="8dp"
            android:layout_gravity="bottom" />

        <!-- Detonation flash overlay -->
        <View
            android:id="@+id/flashView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFFFF"
            android:visibility="gone"
            android:elevation="100dp" />

    </FrameLayout>

    <!-- ══ TOOL PANEL ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="76dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="6dp"
        android:background="#1E1E3A">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tools"
            android:textSize="11sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Scissors -->
        <TextView
            android:id="@+id/toolScissors"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="✂️"
            android:textSize="32sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:background="@drawable/tool_bg"
            android:padding="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scissors"
            android:textSize="9sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Hammer -->
        <TextView
            android:id="@+id/toolHammer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="🔨"
            android:textSize="32sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:background="@drawable/tool_bg"
            android:padding="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hammer"
            android:textSize="9sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Water -->
        <TextView
            android:id="@+id/toolWater"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="💧"
            android:textSize="32sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:background="@drawable/tool_bg"
            android:padding="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Water"
            android:textSize="9sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Fire -->
        <TextView
            android:id="@+id/toolFire"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="🔥"
            android:textSize="32sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:background="@drawable/tool_bg"
            android:padding="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fire"
            android:textSize="9sp"
            android:textColor="#AAAAAA"
            android:gravity="center" />

    </LinearLayout>

</LinearLayout>
