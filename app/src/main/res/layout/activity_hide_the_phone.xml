<?xml version="1.0" encoding="utf-8"?>
<!--
  HideThePhoneGame — single screen
  Guard patrol + key/door puzzle live together on one FrameLayout.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- ═══════════════  TITLE  ═══════════════════════════════════════ -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🧺  Find Key &amp; Hide the Phone!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFD600"
        android:gravity="center"
        android:paddingTop="16dp"
        android:layout_gravity="top" />

    <!-- ═══════════════  HINT (step guidance)  ════════════════════════ -->
    <TextView
        android:id="@+id/tvP1Hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Flip phone face-down 180° to tip the basket 🧺"
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:gravity="center"
        android:padding="10dp"
        android:layout_gravity="top"
        android:layout_marginTop="52dp" />

    <!-- ═══════════════  TABLE SURFACE  ════════════════════════════════ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="#8D6E63"
        android:layout_gravity="center_vertical"
        android:layout_marginBottom="60dp" />

    <!-- ═══════════════  BOX (opens when key drops)  ══════════════════ -->
    <TextView
        android:id="@+id/tvBox"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:text="🧺"
        android:textSize="64sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_marginBottom="80dp"
        android:layout_marginEnd="80dp" />

    <!-- ═══════════════  KEY (hidden until box tips)  ═════════════════ -->
    <TextView
        android:id="@+id/tvKey"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:text="🗝"
        android:textSize="48sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="80dp"
        android:visibility="invisible" />

    <!-- ═══════════════  DOOR  ════════════════════════════════════════ -->
    <TextView
        android:id="@+id/tvDoor"
        android:layout_width="80dp"
        android:layout_height="110dp"
        android:text="🚪"
        android:textSize="72sp"
        android:gravity="center"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="90dp"
        android:layout_marginEnd="24dp" />

    <!-- ═══════════════  GUARD (walks across, animated)  ══════════════ -->
    <TextView
        android:id="@+id/tvGuard"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="💂"
        android:textSize="56sp"
        android:gravity="center"
        android:layout_gravity="center_vertical"
        android:layout_marginTop="60dp"
        android:visibility="invisible" />

    <!-- ═══════════════  GUARD STATUS  ═══════════════════════════════ -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guard is patrolling…"
        android:textSize="15sp"
        android:textColor="#EEEEEE"
        android:gravity="center"
        android:padding="10dp"
        android:background="#55000000"
        android:layout_gravity="center_vertical"
        android:layout_marginTop="200dp" />

    <!-- ═══════════════  SURVIVE COUNTER  ════════════════════════════ -->
    <TextView
        android:id="@+id/tvEscapes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Survived: 0 / 3"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFD600"
        android:gravity="center"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="50dp" />

    <!-- ═══════════════  INSTRUCTIONS  ═══════════════════════════════ -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guard walks by: cover screen with hand OR flip face-down to hide!"
        android:textSize="11sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:layout_marginBottom="16dp" />

</FrameLayout>
