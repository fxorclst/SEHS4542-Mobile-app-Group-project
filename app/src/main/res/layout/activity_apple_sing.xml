<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".game.appleActivity.AppleActivity_sing">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/game_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <ImageView
            android:id="@+id/catwantapple"
            android:layout_width="225dp"
            android:layout_height="225dp"
            app:layout_constraintTop_toBottomOf="@id/apple_3"
            app:layout_constraintEnd_toEndOf="parent"
            android:elevation="4dp"
            app:srcCompat="@drawable/catwantapplee"/>

        <ImageView
            android:id="@+id/tree_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/tree" />

        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="75dp"
            android:text="I am hungry, I want to eat apple !!"
            android:textColor="@color/black"
            android:textSize="25dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/apple_1"
            android:layout_width="131dp"
            android:layout_height="131dp"
            android:layout_marginTop="180dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/apple" />

        <ImageView
            android:id="@+id/apple_2"
            android:layout_width="120dp"
            android:layout_height="178dp"
            android:layout_marginTop="180dp"
            app:layout_constraintStart_toEndOf="@id/apple_1"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/apple" />

        <ImageView
            android:id="@+id/apple_3"
            android:layout_width="125dp"
            android:layout_height="121dp"
            android:layout_marginTop="180dp"
            app:layout_constraintEnd_toStartOf="@id/apple_1"
            app:layout_constraintStart_toStartOf="@id/apple_1"
            app:layout_constraintTop_toTopOf="@id/apple_2"
            app:srcCompat="@drawable/apple" />


        <TextView
            android:id="@+id/timer_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="125dp"
            android:layout_marginEnd="16dp"
            android:background="#80000000"
            android:padding="8dp"
            android:text="Time: 30"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/pause_button_game1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Pause Game"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/win_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/win_score_text_game1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#420B0C"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/win_text"
            app:layout_constraintStart_toStartOf="@id/win_text"
            app:layout_constraintTop_toBottomOf="@id/win_text"
            tools:text="Score: +25" />

        <TextView
            android:id="@+id/win_text"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="125dp"
            android:gravity="center"
            android:text="Oh yeah,good job baby.\nLet's go back home and enjoy the apples."
            android:textColor="@color/black"
            android:textSize="18dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/cat_background"
            android:layout_width="275dp"
            android:layout_height="275dp"
            android:scaleType="centerCrop"
            android:src="@drawable/win_background_image"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.496"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.449" />

        <TextView
            android:id="@+id/code_display_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E3E3E3"
            android:textSize="15dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.498"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.649"
            tools:text="A8X2B9" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cat_background"
            app:layout_constraintVertical_bias="0.3">

            <Button
                android:id="@+id/next_level_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Next Game" />

            <Button
                android:id="@+id/win_replay_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Restart" />

            <Button
                android:id="@+id/win_home_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="Back" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lose_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="150dp"
            android:gravity="center"
            android:text="Time's Up! \nYou are loser!"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="18dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/lose_background"
            android:layout_width="275dp"
            android:layout_height="275dp"
            android:scaleType="centerCrop"
            android:src="@drawable/catangry"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/lose_button_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lose_background"
            app:layout_constraintVertical_bias="0.3">

            <Button
                android:id="@+id/lose_replay_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="Try Again" />

            <Button
                android:id="@+id/lose_home_button"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Back" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <RelativeLayout
        android:id="@+id/pause_container_game1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6000000"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/resume_button_game1"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="continue"
                android:textSize="18sp" />

            <Button
                android:id="@+id/quit_button_game1"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Home page"
                android:textSize="18sp" />
        </LinearLayout>
    </RelativeLayout>
</FrameLayout>
